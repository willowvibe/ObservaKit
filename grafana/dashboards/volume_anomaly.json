{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Row Counts Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "data_volume_rows",
          "legendFormat": "{{table}} ({{dag}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Volume Anomalies",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "data_volume_rows",
          "format": "table",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Deviation from Rolling Average (%)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "observakit_volume_deviation_pct",
          "legendFormat": "{{table}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["observakit", "volume"],
  "time": { "from": "now-7d", "to": "now" },
  "title": "Volume Anomaly",
  "uid": "observakit-volume-anomaly"
}
