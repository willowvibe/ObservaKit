{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Freshness Lag (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "data_freshness_lag_seconds",
          "legendFormat": "{{table}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 7200 }
            ]
          }
        }
      }
    },
    {
      "title": "Freshness Status Overview",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "count(data_freshness_lag_seconds < 3600)",
          "legendFormat": "Healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "Tables with Warning",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "count(data_freshness_lag_seconds >= 3600 and data_freshness_lag_seconds < 7200)",
          "legendFormat": "Warning"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" }
        }
      }
    },
    {
      "title": "Tables in Failure",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "count(data_freshness_lag_seconds >= 7200)",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["observakit", "freshness"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "Data Freshness",
  "uid": "observakit-data-freshness"
}
