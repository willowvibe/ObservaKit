{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "DAG Run Success Rate (7-day rolling)",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(observakit_pipeline_runs_total{state=\"success\"}[7d])) / sum(rate(observakit_pipeline_runs_total[7d])) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Task Duration P50 / P95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(observakit_task_duration_seconds_bucket[1h]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(observakit_task_duration_seconds_bucket[1h]))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "SLA Miss Count",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(observakit_sla_misses_total)",
          "legendFormat": "SLA Misses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "title": "DAG Runs by State",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (state) (observakit_pipeline_runs_total)",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "title": "Failure Heatmap by DAG × Hour",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (dag_id, hour) (observakit_pipeline_failures_by_hour)",
          "legendFormat": "{{dag_id}}"
        }
      ]
    },
    {
      "title": "Recent DAG Runs",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "observakit_pipeline_run_info",
          "format": "table",
          "legendFormat": ""
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "observakit",
    "pipeline-health"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "title": "Pipeline Health",
  "uid": "observakit-pipeline-health",
  "description": "Built by WillowVibe DataSynapse — https://github.com/willowvibe"
}
